{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/server.js"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/check-offres",
      "schedule": "1 0 * * *"
    },
    {
      "path": "/api/cron/activate-interviews",
      "schedule": "* * * * *"
    }
  ]
}

